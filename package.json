{
  "name": "yt-subtitle-extractor",
  "version": "2.0.0",
  "description": "Production-ready YouTube Subtitle Extractor",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./public/output.css --minify",
    "css": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "dev": "concurrently \"npm run css\" \"nodemon server.js\"",
    "start": "node server.js"
  },
  "keywords": [
    "youtube",
    "subtitle",
    "transcript",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "tailwindcss": "^4.3.1",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  }
}
